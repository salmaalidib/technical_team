{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "technical_team (dev)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart"
        },
        {
            // Web run with a PERSISTENT Chrome profile so flutter_secure_storage
            // (localStorage) survives between runs — otherwise each `flutter run
            // -d chrome` opens a fresh temp profile and the saved tokens are
            // wiped, sending you back to /login on every launch.
            "name": "technical_team (dev - web persistent)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "deviceId": "chrome",
            "args": [
                "--web-browser-flag=--user-data-dir=${workspaceFolder}/.dart_tool/chrome-dev-profile"
            ]
        },
        {
            "name": "technical_team (dev - profile)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "flutterMode": "profile"
        },
        {
            "name": "technical_team (dev - release)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "flutterMode": "release"
        }
    ]
}
